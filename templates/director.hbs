<div class="maestro-director-body">
{{#unless ready}}
  <div class="maestro-warn"><i class="fa-solid fa-circle-exclamation"></i> Maestro isn't initialized — check the console and that the audio path is set, then reload.</div>
{{else}}
  {{#if assetWarning}}
  <div class="maestro-warn"><i class="fa-solid fa-triangle-exclamation"></i> Audio Asset Base Path isn't set — set it in module settings and reload.</div>
  {{/if}}

  <div class="maestro-toolbar">
    <input type="search" name="search" placeholder="Search music, ambience, weather…" value="{{search}}" autocomplete="off">
    <div class="mood-toggle" data-tooltip="Mood">
      <button type="button" data-mood="calm" class="{{#if calmActive}}active{{/if}}" {{#unless hasMusic}}disabled{{/unless}} data-tooltip="Calm version"><i class="fa-solid fa-feather"></i></button>
      <button type="button" data-mood="tension" class="{{#if tensionActive}}active{{/if}}" {{#unless canTension}}disabled{{/unless}} data-tooltip="Tense version"><i class="fa-solid fa-bolt"></i></button>
    </div>
  </div>

  <div class="maestro-now">
    <span class="np" data-tooltip="Now playing (music)"><i class="fa-solid fa-music"></i> {{nowMusic}}</span>
    <select name="music-arrangement" data-tooltip="Scene / variant" {{#unless hasMusic}}disabled{{/unless}}>
      {{#each arrangements}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
    </select>
    <button type="button" data-reroll data-tooltip="Re-roll layers" {{#unless hasMusic}}disabled{{/unless}}><i class="fa-solid fa-shuffle"></i></button>
    <button type="button" data-morph data-tooltip="Open the morph pad" {{#unless hasMusic}}disabled{{/unless}}><i class="fa-solid fa-circle-nodes"></i></button>
    <button type="button" data-stop="music" data-tooltip="Stop music"><i class="fa-solid fa-stop"></i></button>
  </div>

  <div class="maestro-scroll">
    <div class="sec-title"><i class="fa-solid fa-music"></i> Music</div>
    {{#each musicGroups}}
      <div class="grp"><i class="{{icon}}"></i> {{label}}</div>
      {{#each items}}
      <button type="button" class="maestro-item {{#if active}}active{{/if}}" data-kind="music" data-id="{{id}}" data-name="{{name}}">
        <i class="{{icon}}"></i><span class="nm">{{name}}</span><span class="sub">{{sub}}</span>
      </button>
      {{/each}}
    {{/each}}

    <div class="sec-title"><i class="fa-solid fa-wind"></i> Ambience</div>
    {{#each ambienceGroups}}
      <div class="grp"><i class="{{icon}}"></i> {{label}}</div>
      {{#each items}}
      <button type="button" class="maestro-item {{#if active}}active{{/if}}" data-kind="amb" data-id="{{id}}" data-name="{{name}}">
        <i class="{{icon}}"></i><span class="nm">{{name}}</span><span class="sub">{{sub}}</span>
      </button>
      {{/each}}
    {{/each}}

    <div class="sec-title"><i class="fa-solid fa-cloud-bolt"></i> Weather</div>
    {{#each weatherItems}}
    <button type="button" class="maestro-item {{#if active}}active{{/if}}" data-kind="weather" data-id="{{id}}" data-name="{{name}}">
      <i class="fa-solid fa-cloud"></i><span class="nm">{{name}}</span>
    </button>
    {{/each}}
  </div>

  <div class="maestro-foot">
    <i class="fa-solid fa-music" data-tooltip="Music volume"></i>
    <input type="range" name="music-volume" min="0" max="1" step="0.05" value="{{musicVolume}}">
    <i class="fa-solid fa-wind" data-tooltip="Ambience volume"></i>
    <input type="range" name="environment-volume" min="0" max="1" step="0.05" value="{{envVolume}}">
    <button type="button" data-stopall data-tooltip="Stop everything"><i class="fa-solid fa-circle-stop"></i></button>
  </div>
{{/unless}}
</div>
