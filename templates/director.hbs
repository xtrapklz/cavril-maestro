<div class="maestro-director-body">
{{#unless ready}}
  <div class="maestro-warn"><i class="fa-solid fa-circle-exclamation"></i> Maestro isn't initialized — check the console and that the audio path is set, then reload.</div>
{{else}}
  {{#if assetWarning}}
  <div class="maestro-warn"><i class="fa-solid fa-triangle-exclamation"></i> Audio Asset Base Path isn't set — set it in module settings and reload.</div>
  {{/if}}

  <div class="maestro-toolbar">
    <input type="search" name="search" placeholder="Search this zone…" value="{{search}}" autocomplete="off">
    <span class="phase-chip {{phase}} {{#unless autoDayNight}}off{{/unless}}" data-tooltip="In-world: {{phase}} — auto day/night is {{#if autoDayNight}}on{{else}}off (set it in module settings){{/if}}"><i class="fa-solid {{phaseIcon}}"></i></span>
    <div class="seg layout-toggle" data-tooltip="Layout">
      <button type="button" data-layout="list" class="{{#if layoutList}}active{{/if}}" data-tooltip="List"><i class="fa-solid fa-list"></i></button>
      <button type="button" data-layout="grid" class="{{#if layoutGrid}}active{{/if}}" data-tooltip="Icon grid"><i class="fa-solid fa-table-cells-large"></i></button>
    </div>
  </div>

  <div class="maestro-tabs" role="tablist">
    <button type="button" data-tab="music" class="{{#if tabMusic}}active{{/if}}"><i class="fa-solid fa-music"></i> Music <span class="cnt">{{counts.music}}</span></button>
    <button type="button" data-tab="amb" class="{{#if tabAmb}}active{{/if}}"><i class="fa-solid fa-wind"></i> Ambience <span class="cnt">{{counts.amb}}</span></button>
    {{#if weatherEnabled}}
    <button type="button" data-tab="weather" class="{{#if tabWeather}}active{{/if}}"><i class="fa-solid fa-cloud-bolt"></i> Weather <span class="cnt">{{counts.weather}}</span></button>
    {{/if}}
    {{#if sbEnabled}}
    <button type="button" data-tab="sfx" class="{{#if tabSfx}}active{{/if}}"><i class="fa-solid fa-bullhorn"></i> Soundboard <span class="cnt">{{counts.sfx}}</span></button>
    {{/if}}
    <button type="button" data-tab="fav" class="{{#if tabFav}}active{{/if}}"><i class="fa-solid fa-star"></i> Favorites <span class="cnt">{{counts.fav}}</span></button>
    <button type="button" data-tab="preset" class="{{#if tabPreset}}active{{/if}}"><i class="fa-solid fa-bolt"></i> Presets <span class="cnt">{{counts.preset}}</span></button>
  </div>

  {{!-- MUSIC ZONE --}}
  <div class="maestro-zone {{#if tabMusic}}active{{/if}}" data-zone="music">
    <div class="maestro-now">
      <span class="np" data-tooltip="Now playing (music)"><i class="fa-solid fa-music"></i> {{nowMusic}}</span>
      <button type="button" class="ct-switch {{#if tensionActive}}on{{/if}}" data-mood-switch {{#unless canTension}}disabled{{/unless}} data-tooltip="Calm ⟷ Tension{{#unless canTension}} (no tense variant for this theme){{/unless}}">
        <span class="ct-opt" data-tooltip="Calm"><i class="fa-solid fa-feather"></i></span>
        <span class="ct-knob"></span>
        <span class="ct-opt" data-tooltip="Tension"><i class="fa-solid fa-bolt"></i></span>
      </button>
    </div>
    <div class="maestro-controls">
      {{#each arrangements}}<button type="button" class="var-btn {{#if selected}}active{{/if}}" data-arrangement="{{id}}">{{label}}</button>{{/each}}
      {{#each customVariations}}<span class="var-group"><button type="button" class="var-btn custom {{#if active}}active{{/if}}" data-variation="{{id}}" data-tooltip="Custom variation"><i class="fa-solid fa-sliders"></i> {{name}}</button><button type="button" class="var-edit" data-variation-edit="{{id}}" data-tooltip="Edit / delete variation"><i class="fa-solid fa-pen"></i></button></span>{{/each}}
      <button type="button" class="var-btn icon" data-add-variation data-tooltip="Save a new variation from the current tracks" {{#unless hasMusic}}disabled{{/unless}}><i class="fa-solid fa-plus"></i></button>
      <button type="button" class="var-btn icon" data-reroll data-tooltip="Re-roll layers" {{#unless hasMusic}}disabled{{/unless}}><i class="fa-solid fa-shuffle"></i></button>
      <button type="button" class="var-btn icon" data-stop="music" data-tooltip="Stop music" {{#unless hasMusic}}disabled{{/unless}}><i class="fa-solid fa-stop"></i></button>
    </div>
    <div class="maestro-scroll layout-{{layout}}">
      {{#each musicGroups}}
        <div class="grp"><i class="{{icon}}"></i> {{label}}</div>
        {{#each items}}
        <div class="maestro-item {{#if active}}active{{/if}}" role="button" tabindex="0" data-kind="music" data-id="{{id}}" data-fav-id="{{favId}}" data-tags="{{tags}}" data-name="{{name}}" data-default="{{base}}" data-cat="{{cat}}">
          <i class="{{icon}}"></i><span class="nm">{{name}}</span><span class="sub">{{sub}}</span>
          <button type="button" class="maestro-fav {{#if fav}}faved{{/if}}" data-fav data-tooltip="Favorite"><i class="fa-solid fa-star"></i></button>
          <button type="button" class="maestro-rename" data-rename data-tooltip="Rename"><i class="fa-solid fa-pen"></i></button>
        </div>
        {{/each}}
      {{/each}}
    </div>
  </div>

  {{!-- AMBIENCE ZONE --}}
  <div class="maestro-zone {{#if tabAmb}}active{{/if}}" data-zone="amb">
    <div class="maestro-now">
      <span class="np" data-tooltip="Now playing (ambience)"><i class="fa-solid fa-wind"></i> {{nowAmb}}</span>
      <button type="button" data-morph-toggle class="{{#unless morphCollapsed}}active{{/unless}}" data-tooltip="{{#if morphCollapsed}}Show{{else}}Minimize{{/if}} the inline mixer" {{#unless hasAmb}}disabled{{/unless}}><i class="fa-solid fa-circle-nodes"></i></button>
      <button type="button" data-morph data-tooltip="Pop out the ambience mixer" {{#unless hasAmb}}disabled{{/unless}}><i class="fa-solid fa-up-right-from-square"></i></button>
      <button type="button" data-stop="environment" data-tooltip="Stop ambience" {{#unless hasAmb}}disabled{{/unless}}><i class="fa-solid fa-stop"></i></button>
    </div>
    {{#if ambMorph}}
    <div class="mini-morph" data-channel="environment">
      <div class="mm-tools">
        <button type="button" data-shuffle data-tooltip="Shuffle track order"><i class="fa-solid fa-shuffle"></i></button>
        <button type="button" data-reset data-tooltip="Reset to full mix"><i class="fa-solid fa-rotate-left"></i></button>
      </div>
      <svg class="mm-svg" viewBox="0 0 440 360" data-cx="220" data-cy="172" data-r="118">
        <circle class="mm-ring" cx="220" cy="172" r="118"></circle>
        <circle class="mm-hub" cx="220" cy="172" r="3"></circle>
        {{#each ambMorph.tracks}}
        <g class="mm-anchor {{#if muted}}muted{{/if}}" data-id="{{id}}" data-x="{{x}}" data-y="{{y}}">
          <circle class="mm-node" cx="{{x}}" cy="{{y}}" r="15"></circle>
          <foreignObject class="mm-ico" x="{{ix}}" y="{{iy}}" width="22" height="22"><div xmlns="http://www.w3.org/1999/xhtml"><i class="{{icon}}"></i></div></foreignObject>
          <text class="mm-label" x="{{lx}}" y="{{ly}}" text-anchor="{{anchor}}">{{label}}</text>
        </g>
        {{/each}}
        <circle class="mm-puck" cx="{{ambMorph.puckX}}" cy="{{ambMorph.puckY}}" r="11"></circle>
      </svg>
      <div class="mm-auto">
        <button type="button" data-auto class="{{#if ambMorph.auto}}active{{/if}}" data-tooltip="Auto-stroll — rotate the mix automatically"><i class="fa-solid {{#if ambMorph.auto}}fa-pause{{else}}fa-play{{/if}}"></i></button>
        <label data-tooltip="Rotation speed"><i class="fa-solid fa-rotate"></i><input type="range" name="auto-rate" min="2" max="60" step="1" value="{{ambMorph.autoRate}}"></label>
        <label data-tooltip="Sway amount"><i class="fa-solid fa-up-down"></i><input type="range" name="auto-amp" min="0" max="0.5" step="0.02" value="{{ambMorph.autoAmp}}"></label>
        <label data-tooltip="Sway speed"><i class="fa-solid fa-wave-square"></i><input type="range" name="auto-freq" min="0.01" max="0.3" step="0.01" value="{{ambMorph.autoFreq}}"></label>
      </div>
    </div>
    {{/if}}
    <div class="maestro-scroll layout-{{layout}}">
      {{#each ambienceGroups}}
        <div class="grp"><i class="{{icon}}"></i> {{label}}</div>
        {{#each items}}
        <div class="maestro-item {{#if active}}active{{/if}}" role="button" tabindex="0" data-kind="amb" data-id="{{id}}" data-rename-id="{{renameId}}" data-fav-id="{{favId}}" data-tags="{{tags}}" data-name="{{name}}" data-default="{{base}}" data-cat="{{cat}}">
          <i class="{{icon}}"></i><span class="nm">{{name}}</span><span class="sub">{{sub}}</span>
          <button type="button" class="maestro-fav {{#if fav}}faved{{/if}}" data-fav data-tooltip="Favorite"><i class="fa-solid fa-star"></i></button>
          <button type="button" class="maestro-rename" data-rename data-tooltip="Rename"><i class="fa-solid fa-pen"></i></button>
        </div>
        {{/each}}
      {{/each}}
    </div>
  </div>

  {{#if weatherEnabled}}
  {{!-- WEATHER ZONE --}}
  <div class="maestro-zone {{#if tabWeather}}active{{/if}}" data-zone="weather">
    <div class="maestro-now">
      <span class="np" data-tooltip="Now playing (weather)"><i class="fa-solid fa-cloud-bolt"></i> {{nowWeather}}</span>
      {{#if autoWeather}}<span class="auto-badge" data-tooltip="Auto Weather is on — weather follows the calendar. Manual picks below override until the calendar next changes."><i class="fa-solid fa-calendar-check"></i> Auto</span>{{/if}}
      <button type="button" data-stop="weather" data-tooltip="Stop weather" {{#unless hasWeather}}disabled{{/unless}}><i class="fa-solid fa-stop"></i></button>
    </div>
    <div class="maestro-scroll layout-{{layout}}">
      {{#each weatherItems}}
      <div class="maestro-item {{#if active}}active{{/if}}" role="button" tabindex="0" data-kind="weather" data-id="{{id}}" data-fav-id="{{favId}}" data-tags="{{tags}}" data-name="{{name}}" data-default="{{base}}" data-cat="{{cat}}">
        <i class="{{icon}}"></i><span class="nm">{{name}}</span>
        <button type="button" class="maestro-fav {{#if fav}}faved{{/if}}" data-fav data-tooltip="Favorite"><i class="fa-solid fa-star"></i></button>
        <button type="button" class="maestro-rename" data-rename data-tooltip="Rename / tag / icon"><i class="fa-solid fa-pen"></i></button>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{#if sbEnabled}}
  {{!-- SOUNDBOARD ZONE --}}
  <div class="maestro-zone {{#if tabSfx}}active{{/if}}" data-zone="sfx">
    <div class="maestro-now">
      {{#unless sbAtRoot}}<button type="button" data-sb-home data-tooltip="Back to main soundboard"><i class="fa-solid fa-arrow-left"></i></button>{{/unless}}
      <span class="np" data-tooltip="{{sbPath}}"><i class="fa-solid {{#if sbAtRoot}}fa-bullhorn{{else}}fa-folder-open{{/if}}"></i> {{#if sbAtRoot}}Soundboard{{else}}{{sbFolderName}}{{/if}} <span class="cnt">{{counts.sfx}}</span></span>
      <button type="button" data-sb-refresh data-tooltip="Rescan folder"><i class="fa-solid fa-rotate"></i></button>
    </div>
    {{#if sbWarning}}<div class="maestro-warn"><i class="fa-solid fa-triangle-exclamation"></i> Set the Soundboard Folder in module settings.</div>{{/if}}
    {{#if sbLoading}}<div class="sb-status"><i class="fa-solid fa-spinner fa-spin"></i> Scanning folder…</div>{{/if}}
    {{#if sbEmpty}}<div class="sb-status"><i class="fa-solid fa-circle-info"></i> Nothing here (check the path / source).</div>{{/if}}
    <div class="maestro-scroll layout-grid">
      {{#each sbDirs}}
      <div class="maestro-item sb-folder {{#if wild}}sb-folder-wild{{/if}}" role="button" tabindex="0" data-kind="sbdir" data-path="{{path}}" data-name="{{name}}" data-default="{{base}}" data-cat="{{cat}}">
        <i class="{{icon}}"></i><span class="nm">{{name}}</span>
        {{#if wild}}<span class="wild-badge" data-tooltip="Wildcard — plays a random sound inside"><i class="fa-solid fa-shuffle"></i></span>{{/if}}
        <button type="button" class="maestro-rename" data-folder-edit data-tooltip="Folder: rename · icon · wildcard"><i class="fa-solid fa-pen"></i></button>
      </div>
      {{/each}}
      {{#each soundboard}}
      <div class="maestro-item {{#if wild}}sb-wild{{/if}}" role="button" tabindex="0" data-kind="sfx" data-id="{{editId}}" data-src="{{src}}" data-srcs="{{srcs}}" data-fav-id="{{favId}}" data-tags="{{tags}}" data-name="{{name}}" data-default="{{base}}" data-cat="{{cat}}">
        <i class="{{icon}}"></i><span class="nm">{{name}}</span>
        {{#if wild}}<span class="wild-badge" data-tooltip="{{count}} variations — random each play">{{count}}</span>{{/if}}
        <button type="button" class="maestro-fav {{#if fav}}faved{{/if}}" data-fav data-tooltip="Favorite"><i class="fa-solid fa-star"></i></button>
        <button type="button" class="maestro-rename" data-rename data-tooltip="Rename · tag · icon"><i class="fa-solid fa-pen"></i></button>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- FAVORITES ZONE --}}
  <div class="maestro-zone {{#if tabFav}}active{{/if}}" data-zone="fav">
    {{#unless favoriteGroups.length}}<div class="sb-status"><i class="fa-solid fa-star"></i> No favorites yet — tap the star on any sound to add it here.</div>{{/unless}}
    <div class="maestro-scroll layout-{{layout}}">
      {{#each favoriteGroups}}
        <div class="grp"><i class="{{icon}}"></i> {{label}}</div>
        {{#each items}}
        <div class="maestro-item" role="button" tabindex="0" draggable="true" data-fav-key="{{kind}}:{{favId}}" data-kind="{{kind}}" data-id="{{id}}" data-src="{{src}}" data-fav-id="{{favId}}" data-name="{{name}}" data-cat="{{cat}}">
          <i class="{{icon}}"></i><span class="nm">{{name}}</span><span class="sub">{{sub}}</span>
          <button type="button" class="maestro-fav faved" data-fav data-tooltip="Remove from favorites"><i class="fa-solid fa-star"></i></button>
        </div>
        {{/each}}
      {{/each}}
    </div>
  </div>

  {{!-- PRESETS ZONE (one trigger per tag) --}}
  <div class="maestro-zone {{#if tabPreset}}active{{/if}}" data-zone="preset">
    {{#unless presets.length}}<div class="sb-status"><i class="fa-solid fa-bolt"></i> No presets yet — tag several sounds with the same word (via the ✎ on any sound) and that tag becomes a one-click scene here.</div>{{/unless}}
    <div class="maestro-scroll preset-list">
      {{#each presets}}
      <div class="preset-group">
        <div class="preset-label"><i class="fa-solid fa-bolt"></i> <span class="nm">{{tag}}</span> <span class="cnt">{{count}}</span></div>
        {{#each cats}}
        <div class="preset-cat"><i class="{{icon}}"></i> {{label}}</div>
        <div class="preset-members layout-grid">
          {{#each items}}
          <div class="maestro-item {{#if active}}active{{/if}}" role="button" tabindex="0" draggable="true" data-preset-member data-tag="{{tag}}" data-key="{{key}}" data-kind="{{kind}}" data-id="{{id}}" data-src="{{src}}" data-cat="{{cat}}" data-name="{{name}}">
            <i class="{{icon}}"></i><span class="nm">{{name}}</span>
            <button type="button" class="maestro-rename" data-preset-rename data-tooltip="Rename in this preset"><i class="fa-solid fa-pen"></i></button>
          </div>
          {{/each}}
        </div>
        {{/each}}
      </div>
      {{/each}}
    </div>
  </div>

  <div class="maestro-foot">
    <i class="fa-solid fa-music" data-tooltip="Music volume"></i>
    <input type="range" name="music-volume" min="0" max="1" step="0.05" value="{{musicVolume}}">
    <i class="fa-solid fa-wind" data-tooltip="Ambience volume"></i>
    <input type="range" name="environment-volume" min="0" max="1" step="0.05" value="{{envVolume}}">
    <i class="fa-solid fa-cloud-bolt" data-tooltip="Weather volume"></i>
    <input type="range" name="weather-volume" min="0" max="1" step="0.05" value="{{weatherVolume}}">
    <i class="fa-solid fa-volume-high" data-tooltip="Soundboard volume"></i>
    <input type="range" name="sfx-volume" min="0" max="1" step="0.05" value="{{sfxVolume}}">
    <button type="button" data-stopall data-tooltip="Stop everything (fades out)"><i class="fa-solid fa-circle-stop"></i></button>
  </div>
{{/unless}}
</div>
