<div class="maestro-morph-body">
{{#if empty}}
  <div class="maestro-warn"><i class="fa-solid fa-circle-info"></i> Start a music soundscape first, then open the pad to morph between its arrangements.</div>
{{else}}
  <div class="mp-title"><i class="fa-solid fa-circle-nodes"></i> {{name}}</div>
  <svg class="mp-svg" viewBox="0 0 300 300" data-soundscape="{{soundscapeId}}">
    <circle class="mp-ring" cx="150" cy="150" r="110"></circle>
    <circle class="mp-hub" cx="150" cy="150" r="2"></circle>
    {{#each anchors}}
    <g class="mp-anchor {{#if active}}active{{/if}}" data-id="{{id}}" data-x="{{x}}" data-y="{{y}}">
      <circle cx="{{x}}" cy="{{y}}" r="7"></circle>
      <text x="{{x}}" y="{{y}}" dy="-11">{{label}}</text>
    </g>
    {{/each}}
    <circle class="mp-puck" cx="{{puckX}}" cy="{{puckY}}" r="11"></circle>
  </svg>
  <div class="mp-hint">Drag the puck toward an arrangement to morph the music.</div>
{{/if}}
</div>
